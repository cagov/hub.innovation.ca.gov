{% extends "layouts/index.njk" %}
{% block content %}
<div id="page-container" class="page-container-ds">
  <div class="breadcrumb" aria-label="Breadcrumb" role="region">
    <a class="crumb" href="https://ca.gov" title="CA.gov">CA.gov</a>
    <span class="crumb separator">/</span>
    <a class="crumb" href="https://innovation.ca.gov" title="Office of Data and Innovation">Office of Data and Innovation</a>
    <span class="crumb separator">/</span>
    <a class="crumb" href="/" title="Innovation Hub">Innovation Hub</a>
    {% if parentid %}
      <span class="crumb separator">/</span>
      {% if parentidlink %}
        <a class="crumb" href="{{ parentidlink }}" title="{{ parentid | safe }}">{{ parentid | safe }}</a>
      {% else %}
        <span class="crumb">{{ parentid | safe }}</span>
      {% endif %}
    {% endif %}
    {% if subparentid %}
      {% if subparentidlink %}
        <span class="crumb separator">/</span>
        <a class="crumb" href="{{ subparentidlink }}" title="{{ subparentid | safe }}">{{ subparentid | safe }}</a>
      {% else %}
        <span class="crumb separator">/</span>
        <span class="crumb">{{ subparentid | safe }}</span>
      {% endif %}
    {% endif %}
    <span class="crumb separator">/</span>
    <span class="crumb current">{{ title | safe }}</span>
  </div>
  <main id="body-content" class="cagov-main">
    <article id="post-{{ page.fileSlug }}" class="cagov-article with-sidebar with-page-nav">
      <div>
      {% if headerlabel or topiclabel %}
      <div class="content-page-labels">
        {% if topiclabel %}<a class="content-page-topic-label" href="/?topic={{ topicslug }}">{{ topiclabel }}</a>{% endif %}
        {% if headerlabel %}<a class="content-page-header header-{{headericon}}" href="/?type={{ formatslug }}"><span class="content-page-header-label">{{ headerlabel }}</span></a>{% endif %}
      </div>
      {% endif %}
      <h1 class="page-title title-cell">
        {{ title | safe }}
      </h1>
      </div>
      <div class="sidebar-container everylayout sidebar-cell" style="z-index: 1;">
        <sidebar space="0" side="left">
          {% block contentNavigation %}
            {% include "page-navigation.njk" %}
          {% endblock %}
        </sidebar>
      </div>
      <div class="cagov-content content-cell">
        {{ content | safe }}
      </div>
    </article>
  </main>
</div>
{% endblock %}